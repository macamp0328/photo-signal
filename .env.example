# Photo Signal environment configuration
# ------------------------------------------------------------
# Copy this file to `.env.local` (or source it directly) and fill
# in the required secrets before running npm scripts.
#
# Never commit real credentials. The `.env.local` filename is
# ignored by git so your private settings remain local only.

# --- Cloudflare R2 (Stage 3 audio uploads) --------------------
# Required: account identifier from the R2 dashboard
R2_ACCOUNT_ID=your-account-id-here

# Required: API token credentials with R2 read/write access
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Optional: direct endpoint override. Leave empty to derive from
# R2_ACCOUNT_ID automatically (`https://<account>.r2.cloudflarestorage.com`).
R2_ENDPOINT=

# Required bucket and optional key prefix (folder-style path)
R2_BUCKET_NAME=photo-signal-audio
R2_PREFIX=prod/audio

# Public URL base (used for summary output). Change if you front
# R2 with a custom domain.
R2_BASE_URL=https://your-account-id-here.r2.cloudflarestorage.com/photo-signal-audio

# Stage 2 output directory (resolved relative to repo root)
R2_INPUT_DIR=scripts/audio-workflow/encode/output

# Comma-separated list of extensions to upload.
R2_INCLUDE_EXTENSIONS=.opus,.json,.md

# Concurrency, skip logic, and dry-run defaults
R2_CONCURRENCY=4
R2_SKIP_EXISTING=true
R2_DRY_RUN=false

# --- Optional app access gate (shared passcode) --------------
# Set VITE_ACCESS_PASSCODE to enable a one-time unlock screen.
# Leave empty to disable gate.
VITE_ACCESS_PASSCODE=

# Session length in hours before guests are asked again.
VITE_ACCESS_SESSION_HOURS=12
