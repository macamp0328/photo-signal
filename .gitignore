# Telemetry data files (session-specific diagnostics)
temp_files/photo-signal-telemetry-*.json

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local
.env
.env.*
!.env.example
*.tsbuildinfo

# Test coverage
coverage

# Playwright test results
test-results/
playwright-report/

# Generated assets under public/assets are ignored by default,
# except tracked test image fixtures.
public/assets/*
!public/assets/test-images/
!public/assets/test-images/**

# Local audio downloads (yt-dlp output)
downloads/

# Source production photos are kept local-only; repo tracks only CSV metadata
assets/prod-photographs/*.jpg
assets/prod-photographs/*.jpeg
assets/prod-photographs/*.png
!assets/prod-photographs/prod-photographs-details.csv


# Audio encoding work directories
scripts/audio-workflow/encode/work/
scripts/audio-workflow/encode/output/

# Generated artifacts from encoding scripts
output/

# Production audio files (served from CDN in production)
# Keep demo files for local development: concert-*.mp3, concert-song-*.mp3
# Add your production MP3 files here to exclude them from git
# Example: public/audio/my-production-track.mp3

