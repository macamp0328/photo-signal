{
  "name": "photo-signal",
  "private": true,
  "version": "0.0.0",
  "description": "A quiet, camera-based gallery that plays music when you point at a printed photo.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc -b --noEmit",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest --run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:visual": "playwright test",
    "test:visual:ui": "playwright test --ui",
    "test:visual:update": "playwright test --update-snapshots",
    "test:visual:report": "playwright show-report --host 0.0.0.0 --port 9323",
    "generate-hashes": "node scripts/generate-photo-hashes.js",
    "create-easy-images": "node scripts/create-easy-test-images.js",
    "create-edge-case-images": "node scripts/create-edge-case-test-images.js",
    "migrate-audio": "node scripts/audio-workflow/update/migrate-audio-to-cdn.js",
    "validate-audio": "node scripts/audio-workflow/update/validate-audio-urls.js",
    "download-song": "node scripts/audio-workflow/download/download-yt-song.js",
    "cleanup-docs": "node scripts/cleanup-docs.js",
    "migrate-audio": "node scripts/audio-workflow/update/migrate-audio-to-cdn.js",
    "validate-audio": "node scripts/audio-workflow/update/validate-audio-urls.js",
    "download-song": "node scripts/audio-workflow/download/download-yt-song.js",
    "pre-commit": "npm audit --audit-level=moderate && npm run lint:fix && npm run format && npm run type-check && npm run test:run && npm run build && ./scripts/check-bundle-size.sh"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "howler": "^2.2.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@playwright/test": "^1.56.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/howler": "^2.2.12",
    "@types/node": "^24.6.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/coverage-v8": "^4.0.8",
    "@vitest/ui": "^4.0.8",
    "canvas": "^3.2.0",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "happy-dom": "^20.0.10",
    "jsdom": "^27.1.0",
    "prettier": "^3.6.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.45.0",
    "vite": "^7.1.12",
    "vitest": "^4.0.8"
  }
}
