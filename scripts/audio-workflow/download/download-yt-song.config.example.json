{
  "playlist-url": "https://music.youtube.com/playlist?list=<replace-with-your-playlist>",
  "output-dir": "~/Music/photo-signal",
  "file-template": "%(playlist_index)02d - %(title)s.%(ext)s",
  "download-archive": "~/Music/photo-signal/.yt-dlp-archive.txt",
  "format-order": "opus,m4a,mp3",
  "sleep-requests": 0.5,
  "rate-limit": "3M",
  "metadata": true,
  "write-info-json": true,
  "write-thumbnail": true,
  "embed-thumbnail": false,
  "add-metadata": false,
  "cookies-from-browser": "chrome"
}
